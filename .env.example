# ============================================================================
# .env.example — copie este arquivo para .env e preencha com suas credenciais
# ============================================================================

# OpenAI (obrigatório — usado para embeddings e LLMs)
OPENAI_API_KEY=

# ============================================================================
# LANGFUSE — telemetria de LLM (opcional)
# ============================================================================
# Crie um projeto em https://cloud.langfuse.com (ou self-host) e cole as chaves.
# Deixe vazio para rodar sem telemetria.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================================================
# POOL DE LLMS — seleção por complexidade da tarefa
# ============================================================================
# simple   → roteamento, classificação, saudação
# medium   → query rewriting, expansão semântica
# complex  → respostas finais dos agentes especializados

LLM_SIMPLE_PROVIDER=openrouter
LLM_SIMPLE_MODEL=nvidia/nemotron-40b-instruct:free

LLM_MEDIUM_PROVIDER=openai
LLM_MEDIUM_MODEL=gpt-4o-mini

LLM_COMPLEX_PROVIDER=openai
LLM_COMPLEX_MODEL=gpt-4o-mini

# Credenciais OpenRouter (usado para modelos free como nvidia/nemotron)
# Crie uma conta em https://openrouter.ai e gere uma API key
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Credenciais MiniMax (opcional — fallback automático para OpenAI se vazio)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.chat/v1

# ============================================================================
# PROMPTS — diretório com os arquivos .md de system prompts dos agentes
# ============================================================================
PROMPTS_DIR=./prompts
